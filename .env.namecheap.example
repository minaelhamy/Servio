APP_NAME=Servio
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://servio.hatchers.ai

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=servio_prod
DB_USERNAME=servio_user
DB_PASSWORD=change-me

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@hatchers.ai"
MAIL_FROM_NAME="${APP_NAME}"

WEBSITE_HOST=servio.hatchers.ai
STORE_SUBDOMAIN_ROUTING=true
Environment=live
